# source a .env file's info into the current shell.
function senv() {
  typeset allexport
  allexport=$(set +o | grep allexport)
  set -a
  source .env
  eval "$allexport"
}

function pyg() {
    pbpaste | pygmentize -f rtf -O "style=friendly,fontface=Source Code Pro" "$1" | pbcopy
}

