# Coretuils
if [ `brew list | grep coreutils` ]; then
    export PATH=`brew --prefix coreutils`:$PATH
fi

# Postgres
export PATH=$PATH:/Applications/Postgres.app/Contents/Versions/latest/bin

# Local stuff
export PATH=~/bin:/usr/local/bin:/usr/local/sbin:/usr/local/heroku/bin:$HOME/.local/bin:$PATH

# NPM
export PATH=$PATH:/usr/local/share/npm/bin

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/jacob/c/google-cloud-sdk/path.bash.inc' ]; then . '/Users/jacob/c/google-cloud-sdk/path.bash.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/jacob/c/google-cloud-sdk/completion.bash.inc' ]; then . '/Users/jacob/c/google-cloud-sdk/completion.bash.inc'; fi
